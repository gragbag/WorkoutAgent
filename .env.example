VITE_SUPABASE_URL=your-project-url
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

WORKOUTAGENT_LLM_PROVIDER=openai_compat
WORKOUTAGENT_LLM_API_URL=https://api.openai.com/v1/chat/completions
WORKOUTAGENT_LLM_API_KEY=your_openai_api_key
WORKOUTAGENT_LLM_MODEL=gpt-4o-mini
WORKOUTAGENT_LLM_TIMEOUT=75
WORKOUTAGENT_ENABLE_VERIFIER=0

# For remote MCP usage with the Responses API, switch the provider to openai_mcp
# and point this URL at a publicly reachable MCP server.
WORKOUTAGENT_MCP_SERVER_URL=https://your-public-mcp-server.example.com/mcp
